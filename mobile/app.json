{
  "expo": {
    "name": "MaCheck",
    "slug": "macheck",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "macheck",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.macheck.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.macheck.app",
      "predictiveBackGestureEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "อนุญาตให้ MaCheck ใช้กล้องเพื่อสแกนฉลากและบาร์โค้ดยา",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-image",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7FBFA",
          "image": "./assets/icon.png",
          "imageWidth": 168,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "notifications": {
        "remotePushEnabled": false
      },
      "eas": {
        "projectId": "4f318cf7-99a1-45bd-b5de-d5f2a0158318"
      }
    },
    "owner": "jamereal"
  }
}
