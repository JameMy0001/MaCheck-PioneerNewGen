rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCaregiverWithPermission(patientUid, permissionName) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(patientUid)/caregiverAccess/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(patientUid)/caregiverAccess/$(request.auth.uid)).data.status == 'active' &&
        get(/databases/$(database)/documents/users/$(patientUid)/caregiverAccess/$(request.auth.uid)).data.permissions[permissionName] == true;
    }

    // Clinical Catalog - Authenticated users can read published data
    match /clinicalMedications/{medId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /clinicalInteractions/{interactionId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /clinicalFoodInteractions/{foodId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /clinicalReleases/{releaseId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Private Handles - Client direct access completely denied (Callable Cloud Functions only)
    match /privateHandles/{handle} {
      allow read, write: if false;
    }

    // User document and subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /medications/{medId} {
        allow read: if isOwner(userId) || isCaregiverWithPermission(userId, 'readMedications');
        allow write: if isOwner(userId);
      }

      match /doseEvents/{eventId} {
        allow read: if isOwner(userId) || isCaregiverWithPermission(userId, 'readDoseEvents');
        allow write: if isOwner(userId);
      }

      match /activityLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /caregiverAccess/{caregiverUid} {
        allow read: if isOwner(userId) || (isAuthenticated() && request.auth.uid == caregiverUid);
        // Only managed via trusted server callables or patient self
        allow write: if isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }

      match /agentRuns/{runId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Caregiver Threads & Messages
    match /caregiverThreads/{threadId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantUids;
      allow create, update: if isAuthenticated() && request.auth.uid in request.resource.data.participantUids;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/caregiverThreads/$(threadId)).data.participantUids;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/caregiverThreads/$(threadId)).data.participantUids && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Caregiver Invitations
    match /caregiverInvites/{inviteId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.patientUid || request.auth.uid == resource.data.caregiverUid);
      allow write: if false; // Handled via Callable Cloud Functions
    }

    // Admin Audit Logs - Client access strictly denied
    match /adminAuditLogs/{auditId} {
      allow read, write: if false;
    }
  }
}
